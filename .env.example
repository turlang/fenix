PORT=3001
HOST=0.0.0.0
NODE_ENV=development
BODY_LIMIT_BYTES=2097152
TRUST_PROXY=false
CORS_ALLOWED_ORIGINS=http://localhost:30000,http://127.0.0.1:30000,http://localhost:3000,http://localhost:3001

# Obrigatórios para publicar narrações. Sem estes campos, o Engine retorna AI_NOT_CONFIGURED.
GROQ_API_KEY=sua_chave_aqui
GROQ_MODEL=defina_um_modelo_disponivel_na_sua_conta_groq

# Histórico persistente usado pelo NoveltyGuard para evitar repetir aberturas.
# Opcional. Padrão: ./data/narration-history.json
MESTRE_ORC_NARRATION_MEMORY_FILE=./data/narration-history.json

# Áudio da narração. O modo browser-tts envia uma diretiva ao módulo Foundry;
# cada navegador converte o texto em voz usando uma voz local em português.
MESTRE_ORC_AUDIO_ENABLED=true
MESTRE_ORC_AUDIO_MODE=browser-tts
MESTRE_ORC_AUDIO_LANGUAGE=pt-BR
MESTRE_ORC_AUDIO_RATE=0.90
MESTRE_ORC_AUDIO_PITCH=0.85
MESTRE_ORC_AUDIO_VOLUME=1.00
